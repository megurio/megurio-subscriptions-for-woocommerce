#. translators: 1: days until retry, 2: current retry count, 3: max retries
msgid "We will automatically retry in %1$d days (retry %2$d/%3$d).<br>You can also pay immediately using the link below."
msgstr "%1$d 日後に自動的に再試行します（リトライ %2$d/%3$d 回目）。<br>それまでの間も、下記リンクからいつでも今すぐお支払いいただけます。"

msgid "Please complete your payment using the link below."
msgstr "下記リンクからお支払い手続きを完了してください。"

#. translators: 1: customer name, 2: order ID, 3: order total, 4: retry line, 5: pay URL
msgid "Dear %1$s,<br><br>The automatic renewal payment for your subscription (Order #%2$d, Amount: %3$s) has failed.<br><br>%4$s<br><br><a href=\"%5$s\" style=\"display:inline-block;padding:10px 20px;background:#7f54b3;color:#fff;text-decoration:none;border-radius:4px;\">Pay Now</a><br><br>Your subscription will be automatically resumed once payment is confirmed.<br>Please contact us if you have any questions."
msgstr "%1$s 様<br><br>定期購入の自動更新（注文 #%2$d、金額: %3$s）の決済処理に失敗しました。<br><br>%4$s<br><br><a href=\"%5$s\" style=\"display:inline-block;padding:10px 20px;background:#7f54b3;color:#fff;text-decoration:none;border-radius:4px;\">今すぐお支払い</a><br><br>お支払いが確認でき次第、定期購入を自動的に再開いたします。<br>ご不明な点がございましたらお問い合わせください。"

msgid "Subscription Renewal Payment Notice"
msgstr "定期購入の更新お支払いについて"

#. translators: 1: current retry count, 2: max retries, 3: customer email
msgid "Retry %1$d/%2$d notification email sent to %3$s."
msgstr "リトライ %1$d/%2$d 回目の通知メールを %3$s へ送信しました。"

#. translators: %d: renewal order ID
msgid "[Important] Subscription renewal could not be completed (Order #%d)"
msgstr "【重要】定期購入の更新が完了できませんでした（注文 #%d）"

#. translators: 1: customer name, 2: order ID, 3: order total, 4: max retries + 1, 5: pay URL
msgid "Dear %1$s,<br><br>We attempted to renew your subscription (Order #%2$d, Amount: %3$s) %4$d times, but all attempts failed.<br><br>No further automatic retries will be made.<br><br>To continue your subscription, please complete payment using the link below.<br>Your subscription will be automatically resumed after payment.<br><br><a href=\"%5$s\" style=\"display:inline-block;padding:10px 20px;background:#7f54b3;color:#fff;text-decoration:none;border-radius:4px;\">Pay Now</a><br><br>Please contact us if you have any questions."
msgstr "%1$s 様<br><br>定期購入の更新（注文 #%2$d、金額: %3$s）を %4$d 回試みましたが、すべて失敗しました。<br><br>以後、自動での再試行は行いません。<br><br>引き続き定期購入をご利用いただくには、下記リンクからお支払いを完了してください。<br>お支払い後、定期購入は自動的に再開されます。<br><br><a href=\"%5$s\" style=\"display:inline-block;padding:10px 20px;background:#7f54b3;color:#fff;text-decoration:none;border-radius:4px;\">今すぐお支払い</a><br><br>ご不明な点がございましたらお問い合わせください。"

msgid "Subscription Renewal Notice"
msgstr "定期購入の更新について"

#. translators: 1: max retries, 2: customer email
msgid "All %1$d retries exhausted. Final notification email sent to %2$s. Auto-charging stopped."
msgstr "%1$d 回のリトライが尽きたため、最終通知メールを %2$s へ送信しました。自動課金を停止しました。"


